PORT=8080

# Shared auth token used by the Next.js app when calling this runner
RUNNER_SERVER_TOKEN=
RUNTIME_SYNC_TOKEN=

# Runtime DB provisioning (when SaaS delegates DB/role creation to runner)
RUNNER_RUNTIME_ADMIN_DATABASE_URL=
RUNNER_RUNTIME_DATABASE_PREFIX=shopify_runtime_
RUNNER_RUNTIME_ROLE_PREFIX=shopify_runtime_
RUNNER_RUNTIME_DB_FORCE_IPV4=true
RUNNER_RUNTIME_DB_CONNECT_TIMEOUT_MS=12000

# Legacy alias
SHOPIFY_MOBILE_AI_SERVER_TOKEN=

# Supabase (used for projects/tasks persistence)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECTS_TABLE=projects
SUPABASE_TASKS_TABLE=tasks

# Vertex / Gemini model execution
VERTEX_API_KEY=
VERTEX_MODEL=gemini-3.1-flash-lite-preview

# Repo cloning and push operations
SHOPIFY_MOBILE_GITHUB_TOKEN=
GITHUB_TOKEN=
GITHUB_OWNER=

# Dev session controls
SHOPIFY_MOBILE_DEV_TIMEOUT_MS=900000
SHOPIFY_MOBILE_DEV_LOG_LIMIT=500
SHOPIFY_MOBILE_EXPO_START_ARGS=--max-workers 1
SHOPIFY_MOBILE_VERBOSE_LOGS=true
SHOPIFY_MOBILE_WEB_WARMUP=false
RUNNER_SERVER_BASE_URL=
RUNNER_REQUIRE_GITHUB_REPO=true
SHOPIFY_MOBILE_EXPO_BACKEND_DEFAULT_PORT=4100
SHOPIFY_MOBILE_EXPO_BACKEND_HEALTH_PATH=/api/health
SHOPIFY_MOBILE_EXPO_BACKEND_START_COMMAND=npm run dev
SHOPIFY_MOBILE_EXPO_BACKEND_HEALTH_TIMEOUT_MS=90000

# Legacy aliases
SHOPIFY_MOBILE_RUNNER_PUBLIC_BASE_URL=
SHOPIFY_MOBILE_PUBLIC_BASE_URL=
SHOPIFY_MOBILE_BACKEND_DEFAULT_PORT=
SHOPIFY_MOBILE_BACKEND_HEALTH_PATH=
SHOPIFY_MOBILE_BACKEND_START_COMMAND=
SHOPIFY_MOBILE_BACKEND_HEALTH_TIMEOUT_MS=
SERVER_HEARTBEAT_MS=30000
SERVER_REQUEST_LOGS=true
SERVER_HEARTBEAT_LOGS=false
SERVER_IDLE_SWEEP_MS=30000
SHOPIFY_MOBILE_USER_IDLE_TIMEOUT_MS=600000

# OpenCode prompt sessions use fixed defaults in code:
# - projects root: /var/shopify-mobile/projects
# - agent: shopify-app-builder
# - timeout: 600000ms
# - max synced file size: 1000000 bytes

# Expo scaffold generation
EXPO_SCAFFOLD_TIMEOUT_MS=300000

# Commit metadata used for auto commits
SHOPIFY_MOBILE_GIT_AUTHOR_NAME=Shopify Mobile AI
SHOPIFY_MOBILE_GIT_AUTHOR_EMAIL=shopify-mobile-ai@local.dev
SHOPIFY_MOBILE_GIT_COMMITTER_NAME=Shopify Mobile AI
SHOPIFY_MOBILE_GIT_COMMITTER_EMAIL=shopify-mobile-ai@local.dev
